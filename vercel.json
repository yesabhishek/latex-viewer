{
  "buildCommand": "npm run build",
  "devCommand": "vite --host 127.0.0.1 --port $PORT",
  "installCommand": "npm install --include=optional && node scripts/install-vercel-tectonic.mjs",
  "outputDirectory": "dist",
  "framework": "vite",
  "functions": {
    "api/compile.ts": {
      "includeFiles": "vendor/bin/**",
      "maxDuration": 60
    }
  }
}
